{
  "expo": {
    "name": "Watchd",
    "slug": "watchd",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "watchd",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0B0D10",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "app.watchd.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "app.watchd.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0B0D10",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0D10",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Watchd uses your photo library so you can choose a profile picture."
        }
      ],
      "expo-image",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
