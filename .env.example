# ── Watchd environment ────────────────────────────────────────────────────────
# Copy to .env and fill in. All EXPO_PUBLIC_* values are embedded in the client
# bundle — never put secrets (service-role keys, shared API tokens) in them.

# Supabase project (create one at https://supabase.com, then Settings → API).
# The anon/publishable key is designed to be public; security comes from RLS.
# Leave both empty to run the app in offline demo mode (no accounts).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# TMDB metadata transport. One of: proxy | direct | demo
#   proxy  – calls the `tmdb-proxy` Supabase Edge Function (production default).
#            Requires: supabase functions deploy tmdb-proxy
#                      supabase secrets set TMDB_API_TOKEN=<your v4 read token>
#   direct – DEV ONLY. Calls TMDB straight from the app using the token below.
#            Do not ship a shared TMDB credential in a public build.
#   demo   – bundled fixture data, works with no keys at all.
# If unset: direct when a token is present, else proxy when Supabase is
# configured, else demo.
EXPO_PUBLIC_TMDB_MODE=

# TMDB API Read Access Token (v4) — https://www.themoviedb.org/settings/api
# Only used in `direct` mode, for local development.
EXPO_PUBLIC_TMDB_ACCESS_TOKEN=

# ── Server-side secrets (NOT part of the app bundle) ─────────────────────────
# Set for the Edge Function with the Supabase CLI, never in this file's .env:
#   supabase secrets set TMDB_API_TOKEN=<your v4 read token>
